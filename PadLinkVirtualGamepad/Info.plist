                <key>IOUserClass</key>
                <string>PadLinkUserClient</string>
                <key>IOServiceDEXTEntitlements</key>
                <array>
                    <string>com.apple.developer.driverkit.userclient-access</string>
                </array>
            </dict>
        </dict>
    </dict>
